flowchart TD
    fb["Framebuffer (FB)<br/>Pixel buffer in memory"]
    plane["Plane<br/>(Primary, Overlay, Cursor)"]
    crtc["CRTC<br/>Timing generator"]
    encoder["Encoder<br/>Signal converter"]
    connector["Connector<br/>Physical output (HDMI)"]
    plane_note["Primary: main display<br/>Overlay: video, HW cursor<br/>Cursor: mouse pointer"]
    crtc_note["Generates timing<br/>Handles scanout<br/>Multiple planes per CRTC"]
