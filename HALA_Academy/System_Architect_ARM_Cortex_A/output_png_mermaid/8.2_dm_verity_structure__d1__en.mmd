flowchart TB
    root["Root Hash (Trusted)"]
    sign["Signed by private key<br/>Stored in verified boot (vbmeta)<br/>or kernel cmdline"]
    subgraph tree["Hash Tree (Metadata)"]
        l1["Layer 1 Hashes"]
        l2["Layer 2 Hashes"]
        ln["Layer N Hashes"]
    end
    subgraph data["Data Blocks (Rootfs)"]
        b0["Block 0"]
        b1["Block 1"]
        b2["Block 2"]
        bn["Block N"]
    end
    ro["Read-only Ext4 / SquashFS<br/>Modification = hash mismatch = I/O error"]
    root -->|Verifies| l1 -->|Verifies| l2 -->|...| ln
    root -.-> sign
    ln -->|Hashes and verifies| b0
    ln -->|Hashes and verifies| b1
    ln -->|Hashes and verifies| b2
    ln -->|Hashes and verifies| bn
    bn -.-> ro
